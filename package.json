{
  "name": "ai-ecosystem-map",
  "version": "1.0.0",
  "description": "Interactive visual map of your AI coding ecosystem: skills, agents, MCP servers, rules — auto-discovered from Claude, Codex, Gemini, Cursor, Windsurf, Copilot configs",
  "main": "bin/cli.js",
  "bin": {
    "ai-ecosystem-map": "bin/cli.js",
    "aem": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "scan": "node bin/cli.js scan",
    "dev": "node bin/cli.js --no-open",
    "dev:ui": "cd ui && npx vite",
    "build:ui": "cd ui && npm run build",
    "build": "cd ui && npm install && npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "cursor",
    "windsurf",
    "copilot",
    "continue",
    "skills",
    "agents",
    "mcp",
    "mcp-servers",
    "visualization",
    "ecosystem",
    "cli",
    "ai-tools",
    "developer-tools",
    "ssh",
    "remote"
  ],
  "author": "Roman Belov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spyrae/ai-ecosystem-map"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "agent/",
    "template/",
    "ui/dist/"
  ],
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "ssh2": "^1.17.0"
  }
}
