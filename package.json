{
  "name": "ai-ecosystem-map",
  "version": "1.0.0",
  "description": "Interactive visual map of your AI coding ecosystem: skills, agents, MCP servers, rules — auto-discovered from Claude, Codex, Gemini, Cursor, Windsurf, Copilot configs",
  "main": "bin/cli.js",
  "bin": {
    "ai-ecosystem-map": "bin/cli.js",
    "aem": "bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "scan": "node bin/cli.js scan",
    "dev": "node bin/cli.js --no-open"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "cursor",
    "windsurf",
    "copilot",
    "skills",
    "agents",
    "mcp",
    "visualization",
    "ecosystem",
    "cli"
  ],
  "author": "Roman Belov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spyrae/ai-ecosystem-map"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "agent/",
    "template/",
    "ui/dist/"
  ]
}
